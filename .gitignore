# 📦 Monorepo EPUB Platform .gitignore

# Dependency directories
node_modules/
**/node_modules/
backend/node_modules/
frontned/node_modules/
# Build outputs
dist/
**/dist/
build/
**/build/
.next/
**/.next/
out/
**/out/

# Environment variables (SENSITIVE - SHOULD NEVER BE COMMITTED)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# IDE Settings
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# OS leftovers
.DS_Store
Thumbs.db

# Tests
coverage/
**/coverage/

# Docker
.docker/
docker-compose.override.yml
